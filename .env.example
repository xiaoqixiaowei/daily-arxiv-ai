# Copy this file to .env for local testing. Do not commit real secrets.

# OpenAI-compatible API settings
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://models.sjtu.edu.cn/api/v1
MODEL_NAME=glm-5.1
LLM_REQUEST_INTERVAL_SECONDS=6.5

# Daily arXiv settings
LANGUAGE=Chinese
CATEGORIES=cs.CV,cs.CL,cs.AI,cs.RO,cs.GR,cs.LG
INCLUDE_KEYWORDS=vlm,vision-language,vision language,visual language,multimodal,world model,world models,video world model,embodied,embodiment,robot,robotic,robotics,manipulation,navigation,game,games,gaming,minecraft,simulation,simulator,reinforcement learning

# Optional: improves GitHub API rate limits when extracting code metadata
TOKEN_GITHUB=your_github_token_here

# Optional: enables local password-protected login testing via setup-local-auth.sh
ACCESS_PASSWORD=your_page_password_here
